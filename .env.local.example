# Supabase – get these from your Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://tuycoafwmrfijlavrzbt.supabase.co
# Publishable key (replaces the legacy anon JWT key – found in Settings → API)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
# Service role key (Settings → API → service_role – keep this SECRET, server-side only)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Bluehost SMTP
# 1. Log in to Bluehost cPanel → Email Accounts → Create Account
#    e.g. nosender@makotechs.com  (set any password)
# 2. Fill in the values below – host is usually mail.yourdomain.com
EMAIL_FROM=nosender@makotechs.com
EMAIL_SMTP_HOST=mail.makotechs.com
EMAIL_PASSWORD=your_bluehost_mailbox_password
